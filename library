		local function chg()
			for i, v in pairs(self.List) do
				if v.Page then
				v.Page.Visible = false
				end
				for i, v in pairs(ScrollingFrame_1:GetChildren()) do
					if v:IsA('Frame') and v:FindFirstChild('Background') then
						v.Background.Position = UDim2.new(0, 0, 0,0)
						v.Background.AnchorPoint = Vector2.new(1 ,0)
					end
				end
				task.spawn(function()
					local children = ScrollingFrame_1:GetChildren()
					for i, v in next, children do
						if v:IsA('Frame') then
							local bg = v:FindFirstChild('Background')
							if bg then
								tw({
									v = bg,
									t = 0.3,
									s = Enum.EasingStyle.Exponential,
									d = "InOut",
									g = {AnchorPoint = Vector2.new(0 ,0)}
								}):Play()
							end
						end
					end
				end)
				if InPage_1 then
				InPage_1.Visible = true
				end
			end
			local tabChildren = TabList_1:GetChildren()
			for i, v in pairs(tabChildren) do
				if v:IsA('Frame') and v.Name ~= 'Line' then
					local func = v:FindFirstChild("Func")
					if func then
						local title = func:FindFirstChild("Title")
						local imageLabel = func:FindFirstChild("ImageLabel")
						if title then
							tw({
								v = title,
								t = 0.15,
								s = Enum.EasingStyle.Linear,
								d = "InOut",
								g = {TextTransparency = 0.7}
							}):Play()
						end
						if imageLabel then
							tw({
								v = imageLabel,
								t = 0.15,
								s = Enum.EasingStyle.Linear,
								d = "InOut",
								g = {ImageTransparency = 0.7}
							}):Play()
						end
						local sbg = v:FindFirstChild("SelectedBg")
						if sbg then
							tw({v = sbg, t = 0.15, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundTransparency = 1}}):Play()
							local ind = sbg:FindFirstChild("Indicator")
							if ind then
								tw({v = ind, t = 0.15, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundTransparency = 1}}):Play()
							end
						end
					end
				end
			end
			tw({
				v = Title_3,
				t = 0.15,
				s = Enum.EasingStyle.Linear,
				d = "InOut",
				g = {TextTransparency = 0}
			}):Play()
			tw({
				v = ImageLabel_2,
				t = 0.15,
				s = Enum.EasingStyle.Linear,
				d = "InOut",
				g = {ImageTransparency = 0}
			}):Play()
			tw({v = SelectedBg, t = 0.15, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundTransparency = 0}}):Play()
			tw({v = Indicator, t = 0.15, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundTransparency = 0}}):Play()
			Page_1.Visible = true
			-- twSelect() -- Disabled old sliding indicator
		end

