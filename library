function TDS:Place(TName, px, py, pz, ...)
    local args = {...}
    local isStacking = args[#args] == "stack" or args[#args] == true

    if isStacking then
        table.remove(args)              
        py = py + 25                    
    end

    if GameState ~= "GAME" then
        return false 
    end

    local targetPos = Vector3.new(px, py, pz)
    
    DoPlaceTower(TName, targetPos, unpack(args))

    local NewT = nil
    while not NewT do
        for _, child in ipairs(workspace.Towers:GetChildren()) do
            local rep = child:FindFirstChild("TowerReplicator")
            if rep and rep:GetAttribute("OwnerId") == LocalPlayer.UserId and rep:GetAttribute("Hologram") ~= true then
                local tName = rep:GetAttribute("Name") or child.Name
                if tName == TName then
                    local alreadyLogged = false
                    for _, t in ipairs(self.PlacedTowers) do
                        if t == child then alreadyLogged = true break end
                    end
                    
                    if not alreadyLogged then
                        local rPos = rep:GetAttribute("Position")
                        local tPos = child.PrimaryPart and child.PrimaryPart.Position or (rPos or child:GetPivot().Position)
                        local dist = (Vector3.new(tPos.X, targetPos.Y, tPos.Z) - targetPos).Magnitude
                        
                        if dist < 5 or (rPos and (Vector3.new(rPos.X, 0, rPos.Z) - Vector3.new(targetPos.X, 0, targetPos.Z)).Magnitude < 5) then
                            NewT = child
                            break
                        end
                    end
                end
            end
        end
        if not NewT then task.wait(0.1) end
    end

    table.insert(self.PlacedTowers, NewT)
    Logger:Log("Successfully recorded placement for: " .. TName .. " (Index: " .. #self.PlacedTowers .. ")")
    return #self.PlacedTowers
end

