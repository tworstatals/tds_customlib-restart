function TDS:IsMatchOver()
    local ok, over = pcall(function()
        local root = PlayerGui:FindFirstChild("ReactGameNewRewards")
        local frame = root and root:FindFirstChild("Frame")
        if not (frame and frame.Visible) then return false end
        local gameOver = frame:FindFirstChild("gameOver")
        if not (gameOver and gameOver.Visible) then return false end
        local rewards = gameOver:FindFirstChild("RewardsScreen")
        return rewards ~= nil and rewards.Visible == true
