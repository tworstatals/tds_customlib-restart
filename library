    Globals.RunningStrats = Globals.RunningStrats or {}

    local function getStratFiles()
        if not isfolder or not makefolder or not listfiles or not readfile then return {} end
        
        if not isfolder("pixelhub") then makefolder("pixelhub") end
        if not isfolder("pixelhub/strats") then makefolder("pixelhub/strats") end
        
        local strats = {}
        local success, files = pcall(function() return listfiles("pixelhub/strats") end)
        if success and files then
            for _, file in ipairs(files) do
                if file:sub(-4) == ".txt" or file:sub(-4) == ".lua" then
                    local filename = file:match("([^/\\\\]+)$") or file
                    local name = filename:sub(1, -5)
                    local fileContent = readfile(file)
                    if fileContent then
                        table.insert(strats, {name = name, content = fileContent})
                    end
                end
            end
        end
        return strats
    end

    Globals.LoadedStrats = {}
    
    local function AddStratToUI(strat)
        if Globals.LoadedStrats[strat.name] then return end
        Globals.LoadedStrats[strat.name] = true
        
        local mode = "Unknown Mode"
        local map = "Unknown Map"
        local towers = {}

        local modeMatch = strat.content:match('TDS:Mode%s*%(%s*"([^"]+)"%s*%)')
        if modeMatch then mode = modeMatch end

        local mapMatch = strat.content:match('TDS:GameInfo%s*%(%s*"([^"]+)"')
        if mapMatch then map = mapMatch end

        local loadoutMatch = strat.content:match('TDS:Loadout%s*%(([^%)]+)%)')
        if loadoutMatch then
            for tower in loadoutMatch:gmatch('"([^"]+)"') do
                table.insert(towers, tower)
            end
        end

        local towersStr = #towers > 0 and table.concat(towers, ", ") or "None"
        local desc = string.format("Map: %s (%s)\nRequires: %s", map, mode, towersStr)

        local savedValue = Globals.RunningStrats[strat.name] or false

        local newToggle = Strategies:Toggle({
            Title = strat.name,
            Desc = desc,
            Value = savedValue,
            Callback = function(v)
                Globals.RunningStrats[strat.name] = v
                SaveSettings() -- Save state whenever a toggle is pressed
                
                if v then
                    if Globals.ActiveStratThreads[strat.name] then return end
                    Globals.ActiveStratThreads[strat.name] = true
                    
                    task.spawn(function()
                        while not (TDS and TDS.Loadout) do
                            task.wait(0.5) 
                        end
                        
                        local currentContent = Globals.StratContents[strat.name] or strat.content
                        local hasAutoRestart = currentContent:match("autorestart%s*=%s*true")
                        local safeContent = currentContent:gsub("while%s+true%s+do", 'while Globals.RunningStrats["' .. strat.name .. '"] do')
                        
                        local envPrep = "local TDS = getgenv().TDS or shared.TDSTable or shared['TDS_Table'] or TDS\n"
                        safeContent = envPrep .. safeContent

                        if hasAutoRestart and not currentContent:match("while%s+true%s+do") then
                            Window:Notify({ Title = "Pixel", Desc = "Running " .. strat.name .. " with Auto-Restart...", Time = 3 })
                            while Globals.RunningStrats[strat.name] do
                                TDS:Reset()
                                TDS:ClearLog()
                                
                                local func, err = loadstring(safeContent)
                                if func then
                                    local ok, runErr = pcall(func)
                                    if not ok then
                                        Window:Notify({ Title = "Pixel Error", Desc = "Runtime error: " .. tostring(runErr), Time = 10, Type = "error" })
                                        break
                                    end
                                else
                                    Window:Notify({ Title = "Pixel Error", Desc = "Syntax error: " .. tostring(err), Time = 10, Type = "error" })
                                    break
                                end
                                
                                if Globals.RunningStrats[strat.name] then
                                    TDS:RestartGame()
                                    task.wait(5)
                                end
                            end
                        else
                            local func, err = loadstring(safeContent)
                            if func then
                                Window:Notify({ Title = "Pixel", Desc = "Running " .. strat.name .. "...", Time = 3 })
                                local ok, runErr = pcall(func)
                                if not ok then
                                    Window:Notify({ Title = "Pixel Error", Desc = "Runtime error: " .. tostring(runErr), Time = 10, Type = "error" })
                                end
                            else
                                Window:Notify({ Title = "Pixel Error", Desc = "Syntax error: " .. tostring(err), Time = 10, Type = "error" })
                            end
                        end
                        
                        Globals.ActiveStratThreads[strat.name] = nil
                    end)
                end
            end
        })
        
        -- Store the toggle reference so we can delete/hide it later
        Globals.LoadedStrats[strat.name] = newToggle
        
        -- NOTE: We removed the explicit autostart block because the UI library's Toggle 
        -- automatically fires its Callback with the initial `Value` ~0.1 seconds after creation!
        -- The callback alone perfectly handles autostarting without spawning duplicate threads.
    end

    Strategies:Section({Title = "Custom Strategies"})

    Globals.StratContents = Globals.StratContents or {}

    Strategies:Button({
        Title = "Refresh Files",
        Desc = "Updates code, adds new, removes deleted strats",
        Callback = function()
            local CurrentStrats = getStratFiles()
            local currentMap = {}
            local added = 0
            local removed = 0
            local updated = 0
            
            for _, strat in ipairs(CurrentStrats) do
                currentMap[strat.name] = true
                
                if not Globals.LoadedStrats[strat.name] then
                    -- Completely new file
                    AddStratToUI(strat)
                    Globals.StratContents[strat.name] = strat.content
                    added = added + 1
                else
                    -- File exists, check if content changed
                    if Globals.StratContents[strat.name] ~= strat.content then
                        Globals.StratContents[strat.name] = strat.content
                        updated = updated + 1
                        
                        -- If it's currently running, we need to stop it so the user can restart it with new code
                        if Globals.RunningStrats[strat.name] then
                            Globals.RunningStrats[strat.name] = false
                            local toggleObj = Globals.LoadedStrats[strat.name]
                            if type(toggleObj) == "table" and toggleObj.SetValue then
                                toggleObj:SetValue(false)
                            end
                            SaveSettings()
                            Window:Notify({Title = "Pixel", Desc = "Stopped " .. strat.name .. " because its file was modified.", Time = 3, Type = "error"})
                        end
                    end
                end
            end
            
            for name, toggleObj in pairs(Globals.LoadedStrats) do
                if not currentMap[name] then
                    if type(toggleObj) == "table" and toggleObj.SetVisible then
                        toggleObj:SetVisible(false)
                    end
                    Globals.LoadedStrats[name] = nil
                    Globals.StratContents[name] = nil
                    Globals.RunningStrats[name] = false
                    removed = removed + 1
                end
            end
            
            if removed > 0 then SaveSettings() end
            Window:Notify({Title = "Pixel", Desc = "Added: " .. added .. " | Removed: " .. removed .. " | Updated: " .. updated, Time = 4})
        end
    })

    -- Initial load
    Globals.StratContents = Globals.StratContents or {}
    local InitialStrats = getStratFiles()
    for _, strat in ipairs(InitialStrats) do
        AddStratToUI(strat)
        Globals.StratContents[strat.name] = strat.content
    end

end

