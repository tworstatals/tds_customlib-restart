local function NormalizeTimeScaleValue(val)
    val = tonumber(val)
    if not val then
        return nil
    end
    for _, v in ipairs(TimeScaleValues) do
        if v == val then
            return v
        end
    end
    return nil
end

local function CoerceTimeScaleValue(val, fallback)
    return NormalizeTimeScaleValue(val) or fallback
end

