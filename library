-- // ===== Session Stats (separate small window) =====
do
    -- read a player stat (Value object, attribute, or leaderstats child)
    local function ReadStat(name)
        -- direct child of player
        local obj = LocalPlayer:FindFirstChild(name)
        if obj then
            local ok, v = pcall(function() return obj.Value end)
            if ok and type(v) == "number" then return v end
        end
        -- attribute on the player
        local attr = LocalPlayer:GetAttribute(name)
        if type(attr) == "number" then return attr end
        -- leaderstats folder fallback
        local ls = LocalPlayer:FindFirstChild("leaderstats")
        if ls then
            local lobj = ls:FindFirstChild(name)
            if lobj then
                local ok, v = pcall(function() return lobj.Value end)
                if ok and type(v) == "number" then return v end
            end
        end
        return nil
    end

    -- format seconds -> HH:MM:SS
    local function FmtTime(sec)
        sec = math.floor(sec)
        local h = math.floor(sec / 3600)
        local m = math.floor((sec % 3600) / 60)
        local s = sec % 60
        return string.format("%02d:%02d:%02d", h, m, s)
    end

    -- cumulative totals gained since execution
    local Totals = { Coins = 0, XP = 0, Gems = 0, Tickets = 0 }
    local Last = {}
    local StartClock = os.clock()

    -- map: display key -> list of stat names to try
    local StatKeys = {
        Coins   = { "Coins" },
        XP      = { "Experience", "XP", "Exp" },
        Gems    = { "Gems" },
        Tickets = { "TimescaleTickets", "Tickets" },
    }

    local function ReadAny(names)
        for _, n in ipairs(names) do
            local v = ReadStat(n)
            if v ~= nil then return v end
        end
        return nil
    end

    -- Live values pushed by the game via RemoteEvent.OnClientEvent
    -- pattern: ("Session", "Update", "Values.Gems", <amount>)
    local EventValues = {}

    -- map the remote "Values.X" path tail -> our display key
    local PathToKey = {
        gems = "Gems",
        coins = "Coins",
        experience = "XP",
        exp = "XP",
        xp = "XP",
        timescaletickets = "Tickets",
        tickets = "Tickets",
    }

    pcall(function()
        local RE = ReplicatedStorage:FindFirstChild("RemoteEvent")
            or ReplicatedStorage:WaitForChild("RemoteEvent", 5)
        if RE then
            RE.OnClientEvent:Connect(function(...)
                local a = {...}
                if a[1] == "Session" and a[2] == "Update" and type(a[3]) == "string" then
                    local tail = a[3]:match("([^%.]+)$")   -- "Values.Gems" -> "Gems"
                    local val = tonumber(a[4])
                    if tail and val then
                        local key = PathToKey[tail:lower()]
                        if key then
                            EventValues[key] = val
                        end
                    end
                end
            end)
        end
    end)

    -- prefer the live event value, fall back to the player stat object
    local function ReadLive(key, names)
        if EventValues[key] ~= nil then
            return EventValues[key]
        end
        return ReadAny(names)
    end

    -- seed the "last" values so we only count gains AFTER execution
    for key, names in pairs(StatKeys) do
        Last[key] = ReadLive(key, names)
    end

    -- build the small window (wrapped in pcall in case the UI lib differs)
    local StatsOk, StatsErr = pcall(function()
        -- snapshot existing window roots so we can find the new one afterwards
        local AetherGui = game:GetService("CoreGui"):FindFirstChild("Pixel")
        local existingShadows = {}
        if AetherGui then
            for _, c in ipairs(AetherGui:GetChildren()) do
                if c.Name == "Shadow" then
                    existingShadows[c] = true
                end
            end
        end

        local StatsWindow = Library:Window({
            Title = "Session Stats",
            Desc = "Gains since execution",
            Theme = "Default",
            Config = {
                Keybind = Enum.KeyCode.RightControl,
                Size = UDim2.new(0, 500, 0, 400)
            }
        })

        if not Globals.ShowSessionStats then
            StatsWindow:SetWindowVisible(false)
        end
        
        Globals.ToggleSessionStats = function(v)
            if StatsWindow and StatsWindow.SetWindowVisible then
                StatsWindow:SetWindowVisible(v)
            end
        end

        -- move the new window so it doesn't sit on top of the main hub
        task.spawn(function()
            AetherGui = AetherGui or game:GetService("CoreGui"):FindFirstChild("Pixel")
            if not AetherGui then return end
            local NewShadow
            local deadline = os.clock() + 5
            repeat
                for _, c in ipairs(AetherGui:GetChildren()) do
                    if c.Name == "Shadow" and not existingShadows[c] then
                        NewShadow = c
                        break
                    end
                end
                if not NewShadow then task.wait(0.1) end
            until NewShadow or os.clock() > deadline

            if NewShadow then
                -- offset to the right of the main window (both are 500 wide -> ~520px gap)
                NewShadow.Position = UDim2.new(0.5, 520, 0.5, 0)
            end
        end)

        local Tab = StatsWindow:Tab({ Title = "Stats", Icon = "chart-bar-increasing" })
        Tab:Section({ Title = "Totals (since start)" })

        local CoinsLbl   = Tab:Label({ Title = "Total Coins: 0", Desc = "" })
        local XPLbl      = Tab:Label({ Title = "Total XP: 0", Desc = "" })
        local GemsLbl    = Tab:Label({ Title = "Total Gems: 0", Desc = "" })
        local TicketsLbl = Tab:Label({ Title = "Total Timescale Tickets: 0", Desc = "" })

        Tab:Section({ Title = "Rate (per hour)" })
        local CoinsPH    = Tab:Label({ Title = "Coins/h: 0", Desc = "" })
        local XPPH       = Tab:Label({ Title = "XP/h: 0", Desc = "" })
        local GemsPH     = Tab:Label({ Title = "Gems/h: 0", Desc = "" })
        local TicketsPH  = Tab:Label({ Title = "Tickets/h: 0", Desc = "" })

        Tab:Section({ Title = "Session" })
        local LevelLbl = Tab:Label({ Title = "Current Level: 0", Desc = "" })
        local TimeLbl  = Tab:Label({ Title = "Time Running: 00:00:00", Desc = "" })

        -- format a per-hour number with comma separators
        local function FmtNum(n)
            n = math.floor(n + 0.5)
            local s = tostring(n)
            local out = s:reverse():gsub("(%d%d%d)", "%1,"):reverse()
            out = out:gsub("^,", "")
            return out
        end

        task.spawn(function()
            while true do
                -- accumulate positive deltas (i.e. amounts gained, ignoring spending)
                for key, names in pairs(StatKeys) do
                    local cur = ReadLive(key, names)
                    if cur ~= nil then
                        local prev = Last[key]
                        if prev ~= nil and cur > prev then
                            Totals[key] = Totals[key] + (cur - prev)
                        end
                        Last[key] = cur
                    end
                end

                local elapsed = os.clock() - StartClock
                local hours = elapsed / 3600
                local function rate(total)
                    if hours <= 0 then return 0 end
                    return total / hours
                end

                local level = ReadStat("Level") or 0

                -- live current values (for display + to prove reads work)
                local curCoins   = ReadLive("Coins", StatKeys.Coins) or 0
                local curXP      = ReadLive("XP", StatKeys.XP) or 0
                local curGems    = ReadLive("Gems", StatKeys.Gems) or 0
                local curTickets = ReadLive("Tickets", StatKeys.Tickets) or 0

                pcall(function()
                    CoinsLbl:SetTitle("Total Coins: " .. FmtNum(Totals.Coins) .. "  (now: " .. FmtNum(curCoins) .. ")")
                    XPLbl:SetTitle("Total XP: " .. FmtNum(Totals.XP) .. "  (now: " .. FmtNum(curXP) .. ")")
                    GemsLbl:SetTitle("Total Gems: " .. FmtNum(Totals.Gems) .. "  (now: " .. FmtNum(curGems) .. ")")
                    TicketsLbl:SetTitle("Total Timescale Tickets: " .. FmtNum(Totals.Tickets) .. "  (now: " .. FmtNum(curTickets) .. ")")

                    CoinsPH:SetTitle("Coins/h: " .. FmtNum(rate(Totals.Coins)))
                    XPPH:SetTitle("XP/h: " .. FmtNum(rate(Totals.XP)))
                    GemsPH:SetTitle("Gems/h: " .. FmtNum(rate(Totals.Gems)))
                    TicketsPH:SetTitle("Tickets/h: " .. FmtNum(rate(Totals.Tickets)))

                    LevelLbl:SetTitle("Current Level: " .. tostring(level))
                    TimeLbl:SetTitle("Time Running: " .. FmtTime(elapsed))
                end)

                task.wait(1)
            end
        end)

        -- ===== Webhook tab (separate left tab, like "Stats") =====
        local WHTab = StatsWindow:Tab({ Title = "Webhook", Icon = "webhook" })
        WHTab:Section({ Title = "Discord Webhook" })

        -- webhook state backed by the persistent config (auto-saves to ADS_Config.json)
        -- falls back to the main hub's WebhookURL the first time if no stats url is set
        if (not Globals.StatsWebhookURL or Globals.StatsWebhookURL == "")
            and Globals.WebhookURL and Globals.WebhookURL ~= "" then
            SetSetting("StatsWebhookURL", Globals.WebhookURL)
        end

        local WH = {
            Url = Globals.StatsWebhookURL or "",
            Auto = Globals.StatsWebhookAuto or false,
        }

        WHTab:Textbox({
            Title = "Webhook URL:",
            Desc = "Where match summaries are sent (auto-saved)",
            Placeholder = "https://discord.com/api/webhooks/...",
            Value = WH.Url,
            ClearTextOnFocus = true,
            Callback = function(value)
                WH.Url = value or ""
                SetSetting("StatsWebhookURL", WH.Url)   -- persist
            end
        })

        WHTab:Toggle({
            Title = "Auto Send (per match)",
            Desc = "Send a summary automatically when each match ends (auto-saved)",
            Value = WH.Auto,
            Callback = function(v)
                WH.Auto = v
                SetSetting("StatsWebhookAuto", v)       -- persist
            end
        })

        -- small number formatter (local to this tab)
        local function WHNum(n)
            n = math.floor(tonumber(n) or 0)
            local s = tostring(n)
            local out = s:reverse():gsub("(%d%d%d)", "%1,"):reverse()
            out = out:gsub("^,", "")
            return out
        end

        -- build the embed payload for a given match-rewards table
        local function BuildPayload(match)
            local statusColor = 3066993            -- green (win)
            if match.Status == "LOSS" then
                statusColor = 15158332             -- red
            elseif match.Status == "UNKNOWN" then
                statusColor = 9807270              -- gray
            end

            -- rewards gained THIS match
            local rewardLines = {
                "Coins: **" .. WHNum(match.Coins) .. "**",
                "Gems: **" .. WHNum(match.Gems) .. "**",
                "XP: **" .. WHNum(match.XP) .. "**",
            }
            if match.Others and #match.Others > 0 then
                for _, item in ipairs(match.Others) do
                    table.insert(rewardLines, (item.Name or "Item") .. ": **" .. tostring(item.Amount) .. "**")
                end
            end

            -- session summary (totals since execution)
            local elapsed = os.clock() - StartClock
            local summaryLines = {
                "Total Coins: **" .. WHNum(Totals.Coins) .. "**",
                "Total Gems: **" .. WHNum(Totals.Gems) .. "**",
                "Total XP: **" .. WHNum(Totals.XP) .. "**",
                "Total Timescale Tickets: **" .. WHNum(Totals.Tickets) .. "**",
                "Runtime: **" .. FmtTime(elapsed) .. "**",
            }

            return {
                username = "Pixel",
                embeds = {{
                    title = "Match Ended - " .. tostring(match.Status),
                    color = statusColor,
                    fields = {
                        { name = "Result", value = string.format("Status: **%s**\nWave: **%d**\nTime: **%s**", tostring(match.Status), match.Wave or 0, match.Time or "00:00"), inline = false },
                        { name = "Rewards Gained", value = table.concat(rewardLines, "\n"), inline = true },
                        { name = "Session Summary", value = table.concat(summaryLines, "\n"), inline = true },
                    },
                    footer = { text = "Pixel - Session Stats" },
                }}
            }
        end

        local function SendPayload(payload)
            if not SendRequest then return false, "no http function" end
            if not WH.Url or WH.Url == "" then return false, "empty url" end
            local ok, res = pcall(function()
                return SendRequest({
                    Url = WH.Url,
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = HttpService:JSONEncode(payload)
                })
            end)
            if ok and res and res.StatusCode and res.StatusCode >= 200 and res.StatusCode < 300 then
                return true
            end
            return false, (ok and res and res.StatusCode) or res
        end

        WHTab:Button({
            Title = "Send Summary Now",
            Desc = "Send the current match + session summary",
            Callback = function()
                if not WH.Url or WH.Url == "" then
                    return Window:Notify({ Title = "Error", Desc = "Webhook URL is empty!", Time = 3, Type = "error" })
                end
                local match = GetAllRewards()
                local ok, err = SendPayload(BuildPayload(match))
                if ok then
                    Window:Notify({ Title = "Webhook", Desc = "Summary sent!", Time = 3, Type = "normal" })
                else
                    Window:Notify({ Title = "Error", Desc = "Failed to send (" .. tostring(err) .. ")", Time = 5, Type = "error" })
                end
            end
        })

        WHTab:Button({
            Title = "Test Webhook",
            Desc = "Send a test message",
            Callback = function()
                if not WH.Url or WH.Url == "" then
                    return Window:Notify({ Title = "Error", Desc = "Webhook URL is empty!", Time = 3, Type = "error" })
                end
                local ok, err = SendPayload({ content = "Webhook Test - Pixel Session Stats" })
                if ok then
                    Window:Notify({ Title = "Webhook", Desc = "Test sent successfully!", Time = 3, Type = "normal" })
                else
                    Window:Notify({ Title = "Error", Desc = "Invalid webhook (" .. tostring(err) .. ")", Time = 5, Type = "error" })
                end
            end
        })

        -- auto-send watcher: fires once per match end while Auto is on
        task.spawn(function()
            local function MatchOver()
                local ok, over = pcall(function()
                    local root = PlayerGui:FindFirstChild("ReactGameNewRewards")
                    local frame = root and root:FindFirstChild("Frame")
                    if not (frame and frame.Visible) then return false end
                    local g = frame:FindFirstChild("gameOver")
                    if not (g and g.Visible) then return false end
                    local r = g:FindFirstChild("RewardsScreen")
                    return r ~= nil and r.Visible == true
                end)
                return ok and over == true
            end

            local sentThisMatch = false
            while true do
                if MatchOver() then
                    if WH.Auto and not sentThisMatch then
                        sentThisMatch = true
                        task.wait(1.5)   -- let the rewards screen fully populate
                        local match = GetAllRewards()
                        pcall(function() SendPayload(BuildPayload(match)) end)
                    end
                else
                    sentThisMatch = false   -- reset for the next match
                end
                task.wait(1)
            end
        end)
    end)

    if not StatsOk then
        warn("[Session Stats] failed to build window: " .. tostring(StatsErr))
    end
end

