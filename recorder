                btn.MouseButton1Click:Connect(open_recorder)
            end)
            open_recorder()
        end

        if game_state == "GAME" then
            local active_conns = {}

            local function bind_towers_folder(towers_folder)
                if not towers_folder then return end

                for _, conn in ipairs(active_conns) do
                    pcall(function() conn:Disconnect() end)
                end
                table.clear(active_conns)

                table.clear(spawned_towers)
                tower_count = 0
                last_wave = 0

                table.insert(active_conns, towers_folder.ChildAdded:Connect(function(tower)
                    if not Globals.record_strat then return end

                    local replicator = tower:WaitForChild("TowerReplicator", 5)
                    if not replicator then return end
                    local owner_id = replicator:GetAttribute("OwnerId")
                    if owner_id and owner_id ~= local_player.UserId then return end
                    if replicator:GetAttribute("Hologram") == true then return end

                    -- Only register a placement once we've CONFIRMED the tower
                    -- actually persisted. Failed / rejected / transient placement
                    -- attempts spawn a tower that is removed almost immediately;
                    -- waiting and re-checking filters those out so we don't record
                    -- duplicate ghost placements.
                    task.wait(0.35)
                    if tower.Parent ~= towers_folder then return end          -- got removed -> was a failed attempt
                    if replicator:GetAttribute("Hologram") == true then return end
                    if spawned_towers[tower] then return end                  -- already counted

                    tower_count = tower_count + 1
                    local my_index = tower_count
                    spawned_towers[tower] = my_index
                    local tower_name = replicator:GetAttribute("Name") or tower.Name
                    local raw_pos = replicator:GetAttribute("Position")

                    local pos_x, pos_y, pos_z
                    if typeof(raw_pos) == "Vector3" then
                        pos_x, pos_y, pos_z = raw_pos.X, raw_pos.Y, raw_pos.Z
                    else
                        local p = tower:GetPivot().Position
                        pos_x, pos_y, pos_z = p.X, p.Y, p.Z
                    end

                    -- Always record placements WITH the stacker flag (, true) so any
                    -- tower can be re-placed at the exact same spot via stacking.
                    local command = 'TDS:Place("' .. tower_name .. '", ' .. tostring(pos_x) .. ', ' .. tostring(pos_y) .. ', ' .. tostring(pos_z) .. ', true)'
                    record_action(command)
                    -- log line WITH a button that opens an action popup (copy this tower / copy coordinates)
                    local coords = tostring(pos_x) .. ", " .. tostring(pos_y) .. ", " .. tostring(pos_z)
                    if menu and menu.LogCopy then
                        menu.LogCopy("Placed " .. tower_name .. " (Index: " .. my_index .. ")", command, coords, tower_name)
                    else
                        log_line("Placed " .. tower_name .. " (Index: " .. my_index .. ")")
                    end
                end))

                table.insert(active_conns, towers_folder.ChildRemoved:Connect(function(tower)
                    if not Globals.record_strat then return end

                    local my_index = spawned_towers[tower]
                    if my_index then
                        record_action(string.format('TDS:Sell(%d)', my_index))
                        log_line("Sold Tower " .. my_index)
                        spawned_towers[tower] = nil
                    end
                end))
            end

            bind_towers_folder(workspace_ref:FindFirstChild("Towers") or workspace_ref:WaitForChild("Towers", 5))

            workspace_ref.ChildAdded:Connect(function(child)
                if child.Name == "Towers" then
                    task.wait(0.1)
                    bind_towers_folder(child)
                end
            end)
        end
    end
end

-- The library loads us and calls the returned function with a context:
--   local RecorderInit = loadstring(game:HttpGet(".../recorder"))()
--   RecorderInit({ Window = Window, ... })
--
-- A standalone user just runs it with no context:
--   loadstring(game:HttpGet(".../recorder"))()
-- so we auto-start once (guarded) when nobody calls us within a moment.
if not Globals.__recorder_started then
    Globals.__recorder_started = true
    task.spawn(function()
        task.wait(0.5)   -- give the library a chance to call init_recorder(ctx) itself
        if not Globals.__recorder_inited then
            pcall(init_recorder)   -- standalone: no context
        end
    end)
end

return function(ctx)
    Globals.__recorder_inited = true
    return init_recorder(ctx)
end
 
