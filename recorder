        -- a log row WITH a button that opens the action popup
        local function gui_log_copy(msg, fullCommand)
            logOrder = logOrder + 1
            local row = Instance.new("Frame")
            row.BackgroundTransparency = 1
            row.Size = UDim2.new(1, 0, 0, 18)
