            for _, c in ipairs(logFrame:GetChildren()) do
                if c:IsA("TextLabel") or c:IsA("Frame") then c:Destroy() end
            end
            logOrder = 0
        end

        -- clipboard helper (executor-dependent)
        local function set_clipboard(text)
            local fn = setclipboard or toclipboard or (Clipboard and Clipboard.set) or writeclipboard
            if fn then
                local ok = pcall(fn, text)
                return ok
            end
            return false
        end

        -- a small floating popup with actions for a placed-tower log row
        local actionPopup = nil
        local function open_action_popup(fullCommand)
            if actionPopup then actionPopup:Destroy() actionPopup = nil end

            local pop = Instance.new("Frame")
            pop.Name = "ActionPopup"
            pop.Size = UDim2.new(0, 260, 0, 92)
            pop.Position = UDim2.new(0.5, -130, 0.5, -46)
