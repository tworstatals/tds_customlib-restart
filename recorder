            closeX.AnchorPoint = Vector2.new(1, 0)
            closeX.Position = UDim2.new(1, -6, 0, 6)
            closeX.Size = UDim2.new(0, 18, 0, 18)
            closeX.BackgroundColor3 = Color3.fromRGB(60, 30, 30)
            closeX.Text = "X"
            closeX.Font = Enum.Font.GothamBold
            closeX.TextSize = 11
            closeX.TextColor3 = Color3.fromRGB(255, 255, 255)
            closeX.ZIndex = 51
            closeX.Parent = pop
            local cxc = Instance.new("UICorner") cxc.CornerRadius = UDim.new(0, 4) cxc.Parent = closeX
            closeX.MouseButton1Click:Connect(function()
                if actionPopup then actionPopup:Destroy() actionPopup = nil end
            end)

            local function popBtn(text, y, color)
                local b = Instance.new("TextButton")
                b.Position = UDim2.new(0, 10, 0, y)
                b.Size = UDim2.new(1, -20, 0, 30)
                b.BackgroundColor3 = color
                b.Text = text
                b.Font = Enum.Font.Gotham
                b.TextSize = 11
                b.TextTruncate = Enum.TextTruncate.AtEnd
                b.TextColor3 = Color3.fromRGB(255, 255, 255)
                b.ZIndex = 51
                b.Parent = pop
                local bc = Instance.new("UICorner") bc.CornerRadius = UDim.new(0, 6) bc.Parent = b
                return b
            end

            -- 1) replace same tower same place (re-runs the exact place command)
            local replaceBtn = popBtn("replace same tower same place", 10, Color3.fromRGB(35, 120, 60))
            replaceBtn.MouseButton1Click:Connect(function()
                run_and_record(fullCommand)
                if actionPopup then actionPopup:Destroy() actionPopup = nil end
            end)

            -- 2) copy full TDS:Place(...)
            local copyBtn = popBtn("copy " .. fullCommand, 48, Color3.fromRGB(60, 60, 80))
            copyBtn.MouseButton1Click:Connect(function()
                local ok = set_clipboard(fullCommand)
                copyBtn.Text = ok and "copied!" or "no clipboard"
                copyBtn.BackgroundColor3 = ok and Color3.fromRGB(35, 120, 60) or Color3.fromRGB(150, 50, 50)
