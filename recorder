        -- open (creating if needed) the recorder menu
        local function open_recorder()
            if not menu then
                menu = build_menu()
                menu_ref_holder.menu = menu   -- so notify() can fall back to it
            end
            menu.Show()
        end
        -- expose a global so it can be opened from anywhere / standalone
        Globals.open_recorder = open_recorder

