        runBtn.AnchorPoint = Vector2.new(1, 0)
        runBtn.Position = UDim2.new(1, -10, 1, -38)
        runBtn.Size = UDim2.new(0, 72, 0, 28)
        runBtn.BackgroundColor3 = Color3.fromRGB(108, 30, 210)
        runBtn.Text = "Run"
        runBtn.Font = Enum.Font.GothamBold
        runBtn.TextSize = 12
        runBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        runBtn.Parent = root
        local rbc = Instance.new("UICorner") rbc.CornerRadius = UDim.new(0, 6) rbc.Parent = runBtn

        -- expose menu interface
