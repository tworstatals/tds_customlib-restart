    -- execute a typed command AND record it verbatim
    local function run_and_record(text)
        text = (text or ""):gsub("^%s+", ""):gsub("%s+$", "")
        if text == "" then return end
        if not Globals.record_strat then
            if menu then menu.Log("Press START before typing commands.") end
            return
        end

        -- write the exact line the user typed
        record_raw(text)
        if menu then menu.Log(">> " .. text) end

        -- block the auto-recorder from also logging this action
        suppress_until = os.clock() + 10

        task.spawn(function()
            local wrapped = "local TDS = getgenv and getgenv().TDS or shared.TDSTable or shared['TDS_Table'] or TDS\n" .. text
            local fn, err = loadstring(wrapped)
            if not fn then
                if menu then menu.Log("Compile error: " .. tostring(err)) end
                suppress_until = os.clock() + 0.3
                return
            end
            local ok, runErr = pcall(fn)
            if not ok and menu then
                menu.Log("Run error: " .. tostring(runErr))
            end
            -- short tail so trailing namecall / ChildAdded events stay suppressed
            suppress_until = os.clock() + 0.5
        end)
    end

    -- read the player's currently-equipped tower names (for the Place builder)
    local function get_equipped_towers()
        local list = {}
        local sr = replicated_storage:FindFirstChild("StateReplicators")
        if sr then
            for _, folder in ipairs(sr:GetChildren()) do
                if folder.Name == "PlayerReplicator" and folder:GetAttribute("UserId") == local_player.UserId then
                    local equipped = folder:GetAttribute("EquippedTowers")
                    if type(equipped) == "string" then
                        local cleaned = equipped:match("%[.*%]")
                        local ok, t = pcall(function() return http_service:JSONDecode(cleaned) end)
                        if ok and type(t) == "table" then
                            for _, name in ipairs(t) do
                                if name and name ~= "None" then table.insert(list, name) end
                            end
                        end
                    end
                end
            end
        end
        return list
    end

    -- direct remote (fire actions ONCE, like a manual placement)
    local RemoteFunc = replicated_storage:FindFirstChild("RemoteFunction")
        or replicated_storage:WaitForChild("RemoteFunction", 5)

    -- parse "x, y, z" (also tolerates spaces / extra junk) -> three numbers
    local function parse_coords(s)
        local nums = {}
        for num in tostring(s):gmatch("-?%d+%.?%d*") do
            nums[#nums + 1] = tonumber(num)
        end
        return nums[1], nums[2], nums[3]
    end

    -- Place a tower ONCE (no retry). The auto-recorder (ChildAdded) records the
    -- resulting tower with the correct index, so we do NOT record manually here.
    local function place_once(towerName, x, y, z)
        if not RemoteFunc or not towerName or towerName == "" then return false end
        if not (x and y and z) then return false end
        local ok = pcall(function()
            -- elevate Y like the manual stacker so it stacks onto whatever is below
            RemoteFunc:InvokeServer("Troops", "Place",
                { Rotation = CFrame.new(), Position = Vector3.new(x, y + 25, z) }, towerName)
        end)
        return ok
    end

    -- Sell a tower by its recorder index ONCE. The auto-recorder (ChildRemoved)
    -- records TDS:Sell(idx) with the correct index.
    local function sell_index(n)
        if not RemoteFunc then return false end
        local target
        for tower, idx in pairs(spawned_towers) do
            if idx == n then target = tower break end
        end
        if not target then
            if menu then menu.Log("No tower with index " .. tostring(n)) end
            return false
        end
        local ok = pcall(function()
            RemoteFunc:InvokeServer("Troops", "Sell", { Troop = target })
        end)
        return ok
    end

    -- Upgrade a single tower by its recorder index ONCE. The namecall hook
    -- auto-records TDS:Upgrade(idx).
    -- did the upgrade remote actually succeed?
    local function upgrade_result_ok(res)
        if res == true then return true end
        if type(res) == "table" and (res.Success == true or res.success == true) then return true end
        return false
    end

    -- Upgrade a single tower (by recorder index). Captures the server result and
    -- records TDS:Upgrade(idx) ONLY when the upgrade is confirmed. Suppresses the
    -- auto-hook so it isn't recorded twice.
    local function upgrade_index(n)
        if not RemoteFunc then return false end
        local target
        for tower, idx in pairs(spawned_towers) do
            if idx == n then target = tower break end
        end
        if not target then
            if menu then menu.Log("No tower with index " .. tostring(n)) end
            return false
        end
        suppress_until = os.clock() + 2   -- block auto-hook for this action
        local ok, res = pcall(function()
            return RemoteFunc:InvokeServer("Troops", "Upgrade", "Set", { Troop = target })
        end)
        if ok and upgrade_result_ok(res) then
            record_raw(string.format("TDS:Upgrade(%d)", n))
            if menu then menu.Log("Upgraded (Index: " .. n .. ")") end
            suppress_until = os.clock() + 0.3
            return true
        end
        suppress_until = 0
        return false
    end

    -- Upgrade ALL of your towers of a given type, but ONLY record each upgrade
    -- that is actually confirmed by the server (skips max-level / no-cash ones).
    local function upgrade_by_type(towerName)
        if not RemoteFunc or not towerName or towerName == "" then return 0 end
        local folder = workspace_ref:FindFirstChild("Towers")
        if not folder then return 0 end

        suppress_until = os.clock() + 30   -- block auto-hook for the whole batch
        local count = 0
        for _, tower in ipairs(folder:GetChildren()) do
            local rep = tower:FindFirstChild("TowerReplicator")
            if rep and rep:GetAttribute("OwnerId") == local_player.UserId
                and rep:GetAttribute("Name") == towerName then
                local idx = resolve_tower_index(tower)
                if idx then
                    suppress_until = os.clock() + 30
                    local ok, res = pcall(function()
                        return RemoteFunc:InvokeServer("Troops", "Upgrade", "Set", { Troop = tower })
                    end)
                    if ok and upgrade_result_ok(res) then
                        record_raw(string.format("TDS:Upgrade(%d)", idx))
                        count += 1
                    end
                    task.wait(0.2)
                end
            end
        end
        suppress_until = os.clock() + 0.3
        return count
    end

