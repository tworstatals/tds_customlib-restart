	-- Select tab function
	local function selectTab(idx)
		for i, v in pairs(Tabs.List) do
			v.Page.Visible = false
			local func = v.TabFrame:FindFirstChild("Func")
			if func then
				local t = func:FindFirstChild("Title")
				local img = func:FindFirstChild("ImageLabel")
				if t then tw({v = t, t = 0.15, s = Enum.EasingStyle.Linear, d = "InOut", g = {TextTransparency = 0.7}}):Play() end
				if img then tw({v = img, t = 0.15, s = Enum.EasingStyle.Linear, d = "InOut", g = {ImageTransparency = 0.7}}):Play() end
			end
		end
		local tab = Tabs.List[idx]
		if tab then
			tab.Page.Visible = true
			local func = tab.TabFrame:FindFirstChild("Func")
			if func then
				local t = func:FindFirstChild("Title")
				local img = func:FindFirstChild("ImageLabel")
				if t then tw({v = t, t = 0.15, s = Enum.EasingStyle.Linear, d = "InOut", g = {TextTransparency = 0}}):Play() end
				if img then tw({v = img, t = 0.15, s = Enum.EasingStyle.Linear, d = "InOut", g = {ImageTransparency = 0}}):Play() end
			end
			-- Move selector
			local tabCenterY = tab.TabFrame.AbsolutePosition.Y + (tab.TabFrame.AbsoluteSize.Y / 2)
			local sfPos = sidebarSF.AbsolutePosition.Y
			local targetY = tabCenterY - sfPos - (selector.AbsoluteSize.Y / 2)
			tw({v = selector, t = 0.3, s = Enum.EasingStyle.Exponential, d = "Out", g = {Position = UDim2.new(0, 0, 0, targetY)}}):Play()
		end
	end

