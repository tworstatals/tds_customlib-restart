			end
			local function close()
				tw({v = popup, t = 0.15, s = Enum.EasingStyle.Exponential, d = "Out", g = {Size = UDim2.new(0, 150, 0, 0)}}):Play()
				task.wait(0.15)
				popup.Visible = false
			end

			c.MouseButton1Click:Connect(function()
				isopen = not isopen
				if isopen then open() else close() end
			end)

			local colorH, colorS, colorV = 1, 1, 1
			local lastColor = nil
			local Mouse = game:GetService("Players").LocalPlayer:GetMouse()
			local colorInput, hueInput

			local function updateColor()
				pickerBtn.BackgroundColor3 = Color3.fromHSV(colorH, colorS, colorV)
				local r2, g2, b2 = pickerBtn.BackgroundColor3.R * 255, pickerBtn.BackgroundColor3.G * 255, pickerBtn.BackgroundColor3.B * 255
				if lastColor ~= pickerBtn.BackgroundColor3 then
					lastColor = pickerBtn.BackgroundColor3
					pcall(CB, math.floor(r2), math.floor(g2), math.floor(b2))
				end
			end

			local clickColor = click(colorImg)
			local clickHue = click(hueBar)

			clickColor.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 then
					if colorInput then colorInput:Disconnect() end
					colorInput = game:GetService("RunService").RenderStepped:Connect(function()
						local cx = math.clamp((Mouse.X - colorImg.AbsolutePosition.X) / colorImg.AbsoluteSize.X, 0, 1)
						local cy = math.clamp((Mouse.Y - colorImg.AbsolutePosition.Y) / colorImg.AbsoluteSize.Y, 0, 1)
						colorS = cx; colorV = 1 - cy
						updateColor()
					end)
				end
			end)
			clickColor.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 and colorInput then colorInput:Disconnect(); colorInput = nil end
			end)

			clickHue.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 then
					if hueInput then hueInput:Disconnect() end
					hueInput = game:GetService("RunService").RenderStepped:Connect(function()
						local hy = math.clamp((Mouse.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
						colorH = 1 - hy
						updateColor()
					end)
				end
			end)
			clickHue.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 and hueInput then hueInput:Disconnect(); hueInput = nil end
			end)

			delay(0, function()
				colorH, colorS, colorV = Color3.toHSV(pickerBtn.BackgroundColor3)
				updateColor()
			end)

			local N = {}
			function N:SetTitle(t) cfg:SetTitle(t) end
			function N:SetDesc(t) cfg:SetDesc(t) end
			function N:SetVisible(t) r.Parent.Visible = t end
			function N:SetValue(ct)
				local nr = (ct.R or 255) / 255
				local ng = (ct.G or 255) / 255
				local nb = (ct.B or 255) / 255
				pickerBtn.BackgroundColor3 = Color3.new(nr, ng, nb)
				colorH, colorS, colorV = Color3.toHSV(Color3.new(nr, ng, nb))
				updateColor()
			end
			return N
		end

		function Func:Button(p)
			local T = p.Title or "Button"
			local D = p.Desc or ""
			local I = p.Image or ""
			local CB = p.Callback or function() end

			local parent = currentSection
			local r, cfg = row(parent, T, D, I, "Button")
			cfg:SetTextTransparencyTitle(0)
			cfg:SetSizeT(50)

			local c = click(r)
			c.MouseButton1Click:Connect(function()
				tw({v = r, t = 0.1, s = Enum.EasingStyle.Back, d = "Out", g = {Size = UDim2.new(0.95, 0, 0.95, 0)}}):Play()
				task.delay(0.05, function()
					tw({v = r, t = 0.1, s = Enum.EasingStyle.Back, d = "Out", g = {Size = UDim2.new(1, 0, 1, 0)}}):Play()
				end)
				pcall(CB)
			end)
		end

		function Func:Label(p)
			local T = p.Title or "Label"
			local D = p.Desc or ""
			local I = p.Image or ""

			local parent = currentSection
			local r, cfg = row(parent, T, D, I, "Label")
			cfg:SetTextTransparencyTitle(0)
			cfg:SetSizeT(0)

			local N = {}
			function N:SetTitle(t) cfg:SetTitle(t) end
			function N:SetDesc(t) cfg:SetDesc(t) end
			function N:SetVisible(t) r.Parent.Visible = t end
			return N
		end

		return Func
	end

	-- Sidebar padding
	Instance.new("UIPadding", tabList).PaddingTop = UDim.new(0, 5)
	Instance.new("UIPadding", tabList).PaddingBottom = UDim.new(0, 5)
	Instance.new("UIPadding", tabList).PaddingLeft = UDim.new(0, 0)

	return Tabs
end

return Library
