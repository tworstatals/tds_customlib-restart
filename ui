	footerText.Size = UDim2.new(1, 0, 1, 0)
	footerText.Font = Enum.Font.Gotham
	footerText.Text = "discord.gg/6qyA3Ssrsu | Pixel"
	footerText.TextColor3 = Color3.fromRGB(130, 130, 140)
	footerText.TextSize = 11
	footerText.TextXAlignment = Enum.TextXAlignment.Center

	-- Dragging
	lak(topbar, shadow)

	-- Tabs data
	local Tabs = {List = {}, DefaultIndex = 1, Value = false, UIToggleKeybind = Keybind}
	local minimized = false
	local fullSize = Size

	-- Close button
	closeBtn.MouseButton1Click:Connect(function()
		tw({v = bg, t = 0.15, s = Enum.EasingStyle.Linear, d = "InOut", g = {GroupTransparency = 1, Size = UDim2.new(1, -5, 1, -5)}}):Play()
		task.wait(0.15)
		shadow.Visible = false
	end)

	-- Minimize
	minBtn.MouseButton1Click:Connect(function()
		minimized = not minimized
		if minimized then
			pageArea.Visible = false
			sidebar.Visible = false
			vLine.Visible = false
			hLine.Visible = false
			fullSize = shadow.Size
			tw({v = shadow, t = 0.3, s = Enum.EasingStyle.Exponential, d = "Out", g = {Size = UDim2.new(0, fullSize.X.Offset, 0, 42)}}):Play()
		else
			pageArea.Visible = true
			sidebar.Visible = true
			vLine.Visible = true
			hLine.Visible = true
			tw({v = shadow, t = 0.3, s = Enum.EasingStyle.Exponential, d = "Out", g = {Size = fullSize}}):Play()
		end
	end)

	-- Keybind toggle
	local keyConn = nil
	local isOpen = true

	local function setupKeybind()
		if keyConn then keyConn:Disconnect() end
		keyConn = U.InputBegan:Connect(function(i)
			if i.KeyCode == Keybind and not U:GetFocusedTextBox() then
				isOpen = not isOpen
				if isOpen then
					shadow.Visible = true
					tw({v = bg, t = 0.15, s = Enum.EasingStyle.Linear, d = "InOut", g = {GroupTransparency = 0, Size = UDim2.new(1, 0, 1, 0)}}):Play()
