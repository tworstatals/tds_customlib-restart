	valBg.BorderSizePixel = 0
	valBg.Size = UDim2.new(0, 100, 0, 20)
	Instance.new("UICorner", valBg).CornerRadius = UDim.new(0, 4)
	local valStroke = Instance.new("UIStroke", valBg)
	valStroke.Color = NL.InputStroke
	valStroke.Thickness = 1
	valStroke.Transparency = 0.9

	local valLabel = Instance.new("TextLabel", valBg)
	valLabel.BackgroundTransparency = 1
	valLabel.Size = UDim2.new(0.8, 0, 1, 0)
	valLabel.Font = Enum.Font.GothamBold
	valLabel.Text = "--"
	valLabel.TextColor3 = NL.Text
	valLabel.TextSize = 10
	valLabel.TextXAlignment = Enum.TextXAlignment.Left
	valLabel.TextTransparency = 0.3
	Instance.new("UIPadding", valBg).PaddingLeft = UDim.new(0, 5)

	local arrow = Instance.new("ImageLabel", valBg)
	arrow.AnchorPoint = Vector2.new(1, 0.5)
	arrow.Position = UDim2.new(1, 0, 0.5, 0)
	arrow.Size = UDim2.new(0, 14, 0, 14)
	arrow.BackgroundTransparency = 1
	arrow.Image = "rbxassetid://14937709869"
	arrow.ImageTransparency = 0.3

	-- Dropdown popup
	local popup = Instance.new("Frame")
	popup.Name = "DropdownPopup"
	popup.Parent = ScreenGui
	popup.BackgroundColor3 = NL.Page
	popup.BorderSizePixel = 0
	popup.Size = UDim2.new(0, 150, 0, 0)
	popup.ClipsDescendants = true
	popup.Visible = false
	local popupCorner = Instance.new("UICorner", popup)
	popupCorner.CornerRadius = UDim.new(0, 4)
	local popupStroke = Instance.new("UIStroke", popup)
	popupStroke.Color = NL.InputStroke
	popupStroke.Thickness = 1
	popupStroke.Transparency = 0.9
	Instance.new("UIPadding", popup).PaddingTop = UDim.new(0, 25)
	Instance.new("UIPadding", popup).PaddingBottom = UDim.new(0, 5)
	Instance.new("UIPadding", popup).PaddingLeft = UDim.new(0, 5)
	Instance.new("UIPadding", popup).PaddingRight = UDim.new(0, 5)

	local searchFrame = Instance.new("Frame", popup)
	searchFrame.Name = "Search"
	searchFrame.Size = UDim2.new(1, 0, 0, 20)
	searchFrame.BackgroundColor3 = NL.InputBg
	local searchCorner = Instance.new("UICorner", searchFrame)
	searchCorner.CornerRadius = UDim.new(0, 4)
	local searchBox = Instance.new("TextBox", searchFrame)
	searchBox.BackgroundTransparency = 1
	searchBox.Size = UDim2.new(1, 0, 1, 0)
	searchBox.Font = Enum.Font.Gotham
	searchBox.PlaceholderText = "Search . . ."
	searchBox.PlaceholderColor3 = Color3.fromRGB(178,178,178)
	searchBox.Text = ""
	searchBox.TextColor3 = NL.Text
	searchBox.TextSize = 11

	local scrollSF = Instance.new("ScrollingFrame", popup)
	scrollSF.Size = UDim2.new(1, 0, 1, 0)
	scrollSF.Position = UDim2.new(0, 0, 0, 25)
	scrollSF.BackgroundTransparency = 1
	scrollSF.ScrollBarThickness = 2
	scrollSF.ScrollBarImageColor3 = NL.Main
	local ull = Instance.new("UIListLayout", scrollSF)
	ull.SortOrder = Enum.SortOrder.LayoutOrder
	ull.Padding = UDim.new(0, 3)
	changeCanvas(scrollSF, ull, 5)

	local Click = click(p2)
	local isopen = false
	local selectedValues = {}
	local selectedItem

	local function updatePopupSize()
		if not isopen then return end
		local h = ull.AbsoluteContentSize.Y + 30
		if h > 200 then h = 200 end
		tw({v = popup, t = 0.15, s = Enum.EasingStyle.Exponential, d = "Out", g = {Size = UDim2.new(0, 150, 0, h)}}):Play()
	end

	searchBox.Changed:Connect(function()
		local st = string.lower(searchBox.Text)
		for _, v in pairs(scrollSF:GetChildren()) do
			if v:IsA("Frame") then
				local tl = v:FindFirstChild("TextLabel")
				v.Visible = st == "" or (tl and string.find(string.lower(tl.Text), st))
			end
		end
		updatePopupSize()
	end)

	local function open()
		if isopen then return end
		popup.Visible = true
		local tx = valBg.AbsolutePosition.X - popup.Parent.AbsolutePosition.X + valBg.Size.X.Offset - 119
		local ty = valBg.AbsolutePosition.Y - popup.Parent.AbsolutePosition.Y + valBg.Size.Y.Offset - 25
		local h = ull.AbsoluteContentSize.Y + 30
		if h > 200 then h = 200 end
		tw({v = popup, t = 0.15, s = Enum.EasingStyle.Linear, d = "Out", g = {Size = UDim2.new(0, 150, 0, h), Position = UDim2.new(0, tx, 0, ty)}}):Play()
		isopen = true
	end

	local function close()
		if not isopen then return end
		local g = tw({v = popup, t = 0.15, s = Enum.EasingStyle.Linear, d = "Out", g = {Size = UDim2.new(0, 150, 0, 0)}})
		g:Play()
		g.Completed:Connect(function() popup.Visible = false; isopen = false end)
	end

	U.InputBegan:Connect(function(A)
		if A.UserInputType == Enum.UserInputType.MouseButton1 then
			local B, C = popup.AbsolutePosition, popup.AbsoluteSize
			if U:GetMouseLocation().X < B.X or U:GetMouseLocation().X > B.X + C.X or U:GetMouseLocation().Y < B.Y - 20 or U:GetMouseLocation().Y > B.Y + C.Y then
				close()
			end
		end
	end)

	Click.MouseButton1Click:Connect(function()
		if not isopen then open() else close() end
	end)

	local items = {}
	function items:Add(text)
		local item = Instance.new("Frame", scrollSF)
		item.Size = UDim2.new(1, 0, 0, 18)
		item.BackgroundTransparency = 0.95
		Instance.new("UICorner", item).CornerRadius = UDim.new(0, 4)
		Instance.new("UIPadding", item).PaddingLeft = UDim.new(0, 5)
		local tl = Instance.new("TextLabel", item)
		tl.BackgroundTransparency = 1
		tl.Size = UDim2.new(1, 0, 1, 0)
		tl.Font = Enum.Font.GothamBold
		tl.Text = text
		tl.TextColor3 = NL.Text
		tl.TextSize = 12
		tl.TextXAlignment = Enum.TextXAlignment.Left
		tl.TextTransparency = 0.8
		local c = click(item)
		c.MouseButton1Click:Connect(function()
			if Multi then
				if selectedValues[text] then selectedValues[text] = nil; tl.TextTransparency = 0.8
				else selectedValues[text] = true; tl.TextTransparency = 0 end
				local sl = {}
				for i, _ in pairs(selectedValues) do table.insert(sl, i) end
				valLabel.Text = #sl > 0 and table.concat(sl, ", ") or "--"
				pcall(Callback, sl)
			else
				for _, v in pairs(scrollSF:GetChildren()) do
					if v:IsA("Frame") and v:FindFirstChild("TextLabel") then
						v.TextLabel.TextTransparency = 0.8
					end
				end
				tl.TextTransparency = 0
				valLabel.Text = text
				pcall(Callback, text)
			end
		end)
		-- Pre-select
		task.delay(0, function()
			if Multi and type(Value) == "table" then
				for _, v in ipairs(Value) do
					if v == text then tl.TextTransparency = 0; selectedValues[text] = true;
						local sl = {}; for i, _ in pairs(selectedValues) do table.insert(sl, i) end; valLabel.Text = table.concat(sl, ", ") end
				end
			elseif text == Value then
				tl.TextTransparency = 0; valLabel.Text = text; pcall(Callback, text)
			end
		end)
	end

	function items:Clear(a)
		if Multi then selectedValues = {}; valLabel.Text = "--"; pcall(Callback, {}) end
		for _, v in ipairs(scrollSF:GetChildren()) do
			if v:IsA("Frame") then
				local tl = v:FindFirstChild("TextLabel")
				if a == nil or (tl and tl.Text == a) then v:Destroy() end
			end
		end
		if a == nil then selectedItem = nil; valLabel.Text = "--" end
	end

	function items:SetValue(v)
		if Multi then
			selectedValues = {}
			if type(v) == "table" then for _, val in ipairs(v) do selectedValues[val] = true end
			else selectedValues[v] = true end
			local sl = {}; for i, _ in pairs(selectedValues) do table.insert(sl, i) end
			valLabel.Text = #sl > 0 and table.concat(sl, ", ") or "--"
			pcall(Callback, sl)
		else
			valLabel.Text = v
			pcall(Callback, v)
		end
	end

	for _, v in ipairs(List) do items:Add(v) end
	return items
end

-- Background row (label + value area)
local function row(parent, title, desc, icon, ty)
	local rb = Instance.new("Frame", parent)
	rb.Name = "RealBackground"
	rb.BackgroundTransparency = 1
	rb.BorderSizePixel = 0
	rb.Size = UDim2.new(1, 0, 0, 35)
	rb.ClipsDescendants = true

	local bg = Instance.new("Frame", rb)
	bg.Name = "Background"
	bg.BackgroundColor3 = NL.Page
	bg.BorderSizePixel = 0
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.ClipsDescendants = true
	Instance.new("UICorner", bg)

	local container = Instance.new("Frame", bg)
	container.Name = "C"
	container.BackgroundTransparency = 1
	container.Size = UDim2.new(1, 0, 1, 0)
	local ull = Instance.new("UIListLayout", container)
	ull.SortOrder = Enum.SortOrder.LayoutOrder
	ull.VerticalAlignment = Enum.VerticalAlignment.Center
	local pad = Instance.new("UIPadding", container)
	pad.PaddingLeft = UDim.new(0, 13)
	pad.PaddingRight = UDim.new(0, 70)

	local tl = Instance.new("TextLabel", container)
	tl.LayoutOrder = 1
	tl.BackgroundTransparency = 1
	tl.Size = UDim2.new(1, 0, 0, 14)
	tl.Font = Enum.Font.GothamBold
	tl.Text = tostring(desc or "")
	tl.TextColor3 = NL.Text
	tl.TextSize = 10
	tl.TextTransparency = 0.7
	tl.TextXAlignment = Enum.TextXAlignment.Left
	tl.TextWrapped = true
	tl.Visible = desc and desc ~= ""

	local titleL = Instance.new("TextLabel", container)
	titleL.BackgroundTransparency = 1
	titleL.Size = UDim2.new(1, 0, 0, 14)
	titleL.Font = Enum.Font.GothamBold
	titleL.Text = tostring(title)
	titleL.TextColor3 = NL.Text
	titleL.TextSize = 12
	titleL.TextXAlignment = Enum.TextXAlignment.Left
	titleL.TextWrapped = true

	local f = {}
	function f:SetTextTransparencyTitle(v) tw({v = titleL, t = 0.15, s = Enum.EasingStyle.Linear, d = "Out", g = {TextTransparency = v}}):Play() end
	function f:SetSizeT(v) pad.PaddingRight = UDim.new(0, v) end
	function f:SetTitle(v) titleL.Text = tostring(v) end
	function f:SetDesc(v) tl.Text = tostring(v); tl.Visible = v and v ~= "" end
	function f:SetVisibleDesc(v) tl.Visible = v end

	-- Auto-size
	task.delay(0.1, function()
		local sz = ull.AbsoluteContentSize.Y + 21
		if rb.Size.Y.Offset ~= sz then rb.Size = UDim2.new(1, 0, 0, sz) end
	end)
	ull:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		task.defer(function()
			local sz = ull.AbsoluteContentSize.Y + 21
			if rb.Size.Y.Offset ~= sz then rb.Size = UDim2.new(1, 0, 0, sz) end
		end)
	end)

	return bg, f
end

