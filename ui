			local boxPad = Instance.new("UIPadding")
			boxPad.Parent = box
			boxPad.PaddingLeft = UDim.new(0, 8)
			boxPad.PaddingTop = UDim.new(0, 8)
			boxPad.PaddingRight = UDim.new(0, 8)
			boxPad.PaddingBottom = UDim.new(0, 8)
