-- Sidebar Items
local function CreateSidebarItem(text, icon, isSelected)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -8, 0, 32)
	btn.BackgroundColor3 = isSelected and Color3.fromRGB(30, 30, 38) or Color3.fromRGB(0,0,0)
	btn.BackgroundTransparency = isSelected and 0 or 1
	btn.Text = ""
	btn.Parent = Sidebar
	CreateCorner(btn, 6)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -30, 1, 0)
	label.Position = UDim2.new(0, 28, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = text
	label.TextColor3 = isSelected and Config.Colors.Text or Config.Colors.TextMuted
	label.TextSize = 14
	label.Font = Enum.Font.GothamMedium
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = btn

	if icon then
		local img = Instance.new("ImageLabel")
		img.Size = UDim2.new(0, 16, 0, 16)
		img.Position = UDim2.new(0, 8, 0.5, 0)
		img.AnchorPoint = Vector2.new(0, 0.5)
		img.BackgroundTransparency = 1
		img.Image = icon
		img.ImageColor3 = isSelected and Config.Colors.Accent or Config.Colors.TextMuted
		img.Parent = btn
	end

	return btn
end

