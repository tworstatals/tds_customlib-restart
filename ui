			function N:SetDesc(t) cfg:SetDesc(t) end
			function N:SetVisible(t) r.Parent.Visible = t end
			function N:SetValue(t) updateSlider(t) end
			function N:SetMin(t) Min = t; if V < t then updateSlider(t) end end
			function N:SetMax(t) Max = t; if V > t then updateSlider(t) end end
			return N
		end

