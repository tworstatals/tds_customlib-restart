					btn.TextSize = 11
					btn.AutoButtonColor = false
					btn.MouseButton1Click:Connect(function()
						if dMulti then
							selected[item] = not selected[item]
							local list = {}
							for _, v in ipairs(dList) do if selected[v] then table.insert(list, v) end end
							boxText.Text = table.concat(list, ", ")
							btn.TextColor3 = selected[item] and THEME.Accent or THEME.TextDim
							pcall(callback, list)
						else
							boxText.Text = item
							menu.Visible = false
							pcall(callback, item)
						end
					end)
					btn.MouseEnter:Connect(function()
						if not (dMulti and selected[item]) then
							tween(btn, { BackgroundColor3 = THEME.PanelBorder }, 0.1)
						end
					end)
					btn.MouseLeave:Connect(function()
						if not (dMulti and selected[item]) then
							tween(btn, { BackgroundColor3 = THEME.InputBg }, 0.1)
						end
					end)
				end
			end
			refresh()

			local open = false
			box.MouseButton1Click:Connect(function()
				open = not open
				if open then
					local abs = box.AbsolutePosition - ScreenGui.AbsolutePosition
					menu.Position = UDim2.new(0, abs.X + 210, 0, abs.Y + 26)
					menu.Size = UDim2.new(0, box.AbsoluteSize.X, 0, math.min(#dList * 24 + 8, 200))
					menu.Visible = true
					tween(arrow, { Rotation = 0 }, 0.15)
				else
					menu.Visible = false
					tween(arrow, { Rotation = 180 }, 0.15)
				end
			end)

			U.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					local mPos = U:GetMouseLocation()
					if menu.Visible then
						local a = menu.AbsolutePosition
						local s = menu.AbsoluteSize
						if mPos.X < a.X or mPos.X > a.X + s.X or mPos.Y < a.Y or mPos.Y > a.Y + s.Y then
							if mPos.X < box.AbsolutePosition.X or mPos.X > box.AbsolutePosition.X + box.AbsoluteSize.X or mPos.Y < box.AbsolutePosition.Y or mPos.Y > box.AbsolutePosition.Y + box.AbsoluteSize.Y then
								menu.Visible = false
								open = false
								tween(arrow, { Rotation = 180 }, 0.15)
							end
						end
					end
				end
			end)

			local New = {}
			function New:SetTitle(t) title.Text = t end
			function New:SetValue(v)
				if dMulti then
					selected = {}
					if type(v) == "table" then for _, x in ipairs(v) do selected[x] = true end end
					local list = {}
					for _, it in ipairs(dList) do if selected[it] then table.insert(list, it) end end
					boxText.Text = table.concat(list, ", ")
					pcall(callback, list)
				else
					boxText.Text = tostring(v)
					pcall(callback, v)
				end
			end
			function New:Clear() end
			function New:Add() end
			function New:SetVisible(v) el.Visible = v end
			return New
		end

