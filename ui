						pcall(callback, kKey)
					end
				end)
			end)

			local New = {}
			function New:SetTitle(t) title.Text = t end
			function New:SetKey(v) kKey = v; box.Text = tostring(v):gsub("Enum.KeyCode.", ""); pcall(callback, v) end
			function New:SetVisible(v) el.Visible = v end
			return New
		end

		-- ColorPicker (simplified)
