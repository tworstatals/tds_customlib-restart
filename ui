	minBtn.Position = UDim2.new(1, -36, 0.5, 0)
	minBtn.Size = UDim2.new(0, 16, 0, 16)
	minBtn.BackgroundTransparency = 1
	minBtn.Image = "rbxassetid://13857987062"
	minBtn.ImageTransparency = 0.5

