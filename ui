		-- Logger
		function Tab:CreateLogger(p)
			local lTitle = p.Title or "LOGS"
			local lSize = p.Size or UDim2.new(1, 0, 0, 200)
			local el = addElement(lSize.Y.Offset + 10)
			local container = Instance.new("Frame")
			container.Parent = el
			container.Size = lSize
			container.BackgroundColor3 = THEME.InputBg
			container.BorderSizePixel = 0
			round(container, 6)
			stroke(container, THEME.InputBorder, 1, 0.8)

			local top = Instance.new("TextLabel")
			top.Parent = container
			top.BackgroundTransparency = 1
			top.Position = UDim2.new(0, 10, 0, 4)
			top.Size = UDim2.new(1, -20, 0, 18)
			top.Font = Enum.Font.GothamBold
			top.Text = lTitle
			top.TextColor3 = THEME.TextDim
			top.TextSize = 10
			top.TextXAlignment = Enum.TextXAlignment.Left

			local scroll = Instance.new("ScrollingFrame")
			scroll.Parent = container
			scroll.Position = UDim2.new(0, 4, 0, 24)
			scroll.Size = UDim2.new(1, -8, 1, -28)
			scroll.BackgroundTransparency = 1
			scroll.BorderSizePixel = 0
			scroll.ScrollBarThickness = 2
			scroll.ScrollBarImageColor3 = THEME.Accent
			scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
			scroll.CanvasSize = UDim2.new(0, 0, 0, 0)

			local scrollList = Instance.new("UIListLayout")
			scrollList.Parent = scroll
			scrollList.SortOrder = Enum.SortOrder.LayoutOrder
			scrollList.Padding = UDim.new(0, 2)

			local Logger = {}
			function Logger:Log(msg)
				local lbl = Instance.new("TextLabel")
				lbl.Parent = scroll
				lbl.BackgroundTransparency = 1
				lbl.Size = UDim2.new(1, 0, 0, 16)
				lbl.Font = Enum.Font.Code
				lbl.Text = tostring(msg)
				lbl.TextColor3 = THEME.TextDim
				lbl.TextSize = 11
				lbl.TextXAlignment = Enum.TextXAlignment.Left
				scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
			end
			function Logger:Clear()
				for _, c in ipairs(scroll:GetChildren()) do
					if c:IsA("TextLabel") then c:Destroy() end
				end
			end
			return Logger
		end

		return Tab
	end

	-- Notify
	function Window:Notify(p)
		local nTitle = p.Title or "Notify"
		local nDesc = p.Desc or ""
		local nTime = p.Time or 3
		local nType = p.Type or "normal"

		local color = THEME.Accent
		if nType == "error" then color = THEME.Error
		elseif nType == "success" then color = THEME.Success
		elseif nType == "warning" then color = THEME.Warning end

		local notif = Instance.new("Frame")
		notif.Parent = ScreenGui
		notif.AnchorPoint = Vector2.new(1, 1)
		notif.Position = UDim2.new(1, -20, 1, -20)
		notif.Size = UDim2.new(0, 260, 0, 0)
		notif.BackgroundColor3 = THEME.Panel
		notif.BorderSizePixel = 0
		notif.ClipsDescendants = true
		notif.AutomaticSize = Enum.AutomaticSize.Y
		notif.ZIndex = 100
		round(notif, 8)
		stroke(notif, color, 1, 0.6)

		local bar = Instance.new("Frame")
		bar.Parent = notif
		bar.Size = UDim2.new(0, 0, 0, 3)
		bar.Position = UDim2.new(0, 0, 1, -3)
		bar.BackgroundColor3 = color
		bar.BorderSizePixel = 0
		bar.ZIndex = 101

		local pad = Instance.new("UIPadding")
		pad.Parent = notif
		pad.PaddingLeft = UDim.new(0, 12)
		pad.PaddingRight = UDim.new(0, 12)
		pad.PaddingTop = UDim.new(0, 10)
		pad.PaddingBottom = UDim.new(0, 10)

		local tLbl = Instance.new("TextLabel")
		tLbl.Parent = notif
		tLbl.BackgroundTransparency = 1
		tLbl.Size = UDim2.new(1, 0, 0, 18)
		tLbl.Font = Enum.Font.GothamBold
		tLbl.Text = nTitle
		tLbl.TextColor3 = THEME.Text
		tLbl.TextSize = 12
		tLbl.TextXAlignment = Enum.TextXAlignment.Left
		tLbl.RichText = true

		if nDesc ~= "" then
			local dLbl = Instance.new("TextLabel")
			dLbl.Parent = notif
			dLbl.BackgroundTransparency = 1
			dLbl.Size = UDim2.new(1, 0, 0, 0)
			dLbl.AutomaticSize = Enum.AutomaticSize.Y
			dLbl.Font = Enum.Font.Gotham
			dLbl.Text = nDesc
			dLbl.TextColor3 = THEME.TextDim
			dLbl.TextSize = 11
			dLbl.TextXAlignment = Enum.TextXAlignment.Left
			dLbl.TextWrapped = true
			dLbl.RichText = true
		end

		notif.Size = UDim2.new(0, 260, 0, 0)
		tween(notif, { Size = UDim2.new(0, 260, 0, notif.AbsoluteSize.Y) }, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
		tween(bar, { Size = UDim2.new(1, 0, 0, 3) }, nTime, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)

		task.delay(nTime, function()
			tween(notif, { Position = UDim2.new(1, 20, notif.Position.Y.Scale, notif.Position.Y.Offset) }, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
			task.wait(0.3)
			notif:Destroy()
		end)
	end

	-- Dialog
	function Window:Dialog(p)
		local dTitle = p.Title or "Confirm?"
		local b1 = p.Button1 or {}
		local b2 = p.Button2 or {}
		local b1Title = b1.Title or "Yes"
		local b2Title = b2.Title or "No"
		local b1Callback = b1.Callback or function() end
		local b2Callback = b2.Callback or function() end

		local overlay = Instance.new("Frame")
		overlay.Parent = Background
		overlay.Size = UDim2.new(1, 0, 1, 0)
		overlay.BackgroundColor3 = Color3.new(0, 0, 0)
		overlay.BackgroundTransparency = 0.4
		overlay.ZIndex = 90
		overlay.BorderSizePixel = 0

		local dialog = Instance.new("Frame")
		dialog.Parent = overlay
		dialog.AnchorPoint = Vector2.new(0.5, 0.5)
		dialog.Position = UDim2.new(0.5, 0, 0.5, 0)
		dialog.Size = UDim2.new(0, 360, 0, 160)
		dialog.BackgroundColor3 = THEME.Panel
		dialog.BorderSizePixel = 0
		dialog.ZIndex = 91
		round(dialog, 12)
		stroke(dialog, THEME.PanelBorder, 1, 0.8)

		local tLbl = Instance.new("TextLabel")
		tLbl.Parent = dialog
		tLbl.BackgroundTransparency = 1
		tLbl.Position = UDim2.new(0, 20, 0, 16)
		tLbl.Size = UDim2.new(1, -40, 0, 24)
		tLbl.Font = Enum.Font.GothamBold
		tLbl.Text = dTitle
		tLbl.TextColor3 = THEME.Text
		tLbl.TextSize = 14
		tLbl.TextXAlignment = Enum.TextXAlignment.Left
		tLbl.RichText = true
		tLbl.ZIndex = 92

		local btnRow = Instance.new("Frame")
		btnRow.Parent = dialog
		btnRow.AnchorPoint = Vector2.new(0.5, 1)
		btnRow.Position = UDim2.new(0.5, 0, 1, -16)
		btnRow.Size = UDim2.new(1, -40, 0, 36)
		btnRow.BackgroundTransparency = 1
		btnRow.ZIndex = 92

		local btnLayout = Instance.new("UIListLayout")
		btnLayout.Parent = btnRow
		btnLayout.FillDirection = Enum.FillDirection.Horizontal
		btnLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
		btnLayout.VerticalAlignment = Enum.VerticalAlignment.Center
		btnLayout.Padding = UDim.new(0, 12)

		local function makeDlgBtn(text, color, cb)
			local b = Instance.new("TextButton")
			b.Parent = btnRow
			b.Size = UDim2.new(0, 120, 1, 0)
			b.BackgroundColor3 = color or THEME.InputBg
			b.BorderSizePixel = 0
			b.Font = Enum.Font.GothamBold
			b.Text = text
			b.TextColor3 = THEME.Text
			b.TextSize = 12
			b.AutoButtonColor = false
			b.ZIndex = 93
			round(b, 6)
			b.MouseEnter:Connect(function() tween(b, { BackgroundColor3 = THEME.PanelBorder }, 0.15) end)
			b.MouseLeave:Connect(function() tween(b, { BackgroundColor3 = color or THEME.InputBg }, 0.15) end)
			b.MouseButton1Click:Connect(function()
				pcall(cb)
				overlay:Destroy()
			end)
			return b
		end

		makeDlgBtn(b1Title, b1.Color or THEME.Accent, b1Callback)
		makeDlgBtn(b2Title, b2.Color or THEME.ToggleOff, b2Callback)
	end

	-- Show window
	Shadow.Visible = true
	Background.Size = UDim2.new(1, 0, 1, 0) - UDim2.fromOffset(5, 5)
	tween(Background, { Size = UDim2.new(1, 0, 1, 0) }, 0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

	return Window
end

return Library
