			Dsc.TextWrapped = true
			Dsc.AutomaticSize = Enum.AutomaticSize.Y
			addToTheme('Text & Icon', Dsc)
		end

		-- Animate bar
		tw({v = Bar, t = Time, s = Enum.EasingStyle.Linear, d = "InOut", g = {Size = UDim2.new(0, 0, 0, 3)}}):Play()
		task.delay(Time, function()
			local fade = tw({v = Toast, t = 0.3, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundTransparency = 1}})
			fade:Play()
			if Ttl then tw({v = Ttl, t = 0.3, s = Enum.EasingStyle.Linear, d = "Out", g = {TextTransparency = 1}}):Play() end
			if Dsc then tw({v = Dsc, t = 0.3, s = Enum.EasingStyle.Linear, d = "Out", g = {TextTransparency = 1}}):Play() end
			tw({v = Bar, t = 0.3, s = Enum.EasingStyle.Linear, d = "Out", g = {BackgroundTransparency = 1}}):Play()
			fade.Completed:Wait()
			Toast:Destroy()
		end)
	end

