	local isOpen = true
	local function toggleUI()
		isOpen = not isOpen
		if isOpen then
			Shadow_1.Visible = true
			Background_1.GroupTransparency = 1
			Background_1.Size = savedCloseSize - UDim2.fromOffset(6, 6)
			tw({v = Background_1, t = 0.2, s = Enum.EasingStyle.Linear, d = "Out", g = {GroupTransparency = 0, Size = savedCloseSize}}):Play()
		else
			savedCloseSize = Background_1.Size
			local close = tw({v = Background_1, t = 0.2, s = Enum.EasingStyle.Linear, d = "InOut", g = {GroupTransparency = 1, Size = savedCloseSize - UDim2.fromOffset(6, 6)}})
			close:Play()
			close.Completed:Wait()
			Shadow_1.Visible = false
		end
	end

	local function setupKeybind()
		if keybindConnection then keybindConnection:Disconnect() end
		keybindConnection = U.InputBegan:Connect(function(i)
			if Tabs.UIToggleKeybind and i.KeyCode == Tabs.UIToggleKeybind then
				local focused = U:GetFocusedTextBox()
				if not focused then toggleUI() end
			end
		end)
	end
	setupKeybind()

	function Tabs:SetUIToggleKeybind(newKeybind)
		Tabs.UIToggleKeybind = newKeybind
		setupKeybind()
	end
	function Tabs:GetUIToggleKeybind()
		return Tabs and Tabs.UIToggleKeybind or nil
	end

	return Tabs
end

return Library
